<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fillViewport="true"
    android:background="?attr/android:colorBackground">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="center_horizontal"
        android:paddingHorizontal="32dp"
        android:paddingTop="48dp"
        android:paddingBottom="32dp">

        <!-- logo de la aplicacion -->
        <ImageView
            android:layout_width="120dp"
            android:layout_height="120dp"
            android:src="@drawable/ic_pasedegol"
            android:contentDescription="Logo de PaseDeGol" />

        <!-- nombre de la aplicacion -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:text="PaseDeGol"
            android:textSize="28sp"
            android:textStyle="bold"
            android:textColor="@color/green_primary" />

        <!-- version de la aplicacion -->
        <TextView
            android:id="@+id/tvVersion"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:textSize="14sp"
            android:textColor="?attr/colorOnSurfaceVariant"
            tools:text="Versión 1.0.0" />

        <!-- separador -->
        <View
            android:layout_width="60dp"
            android:layout_height="2dp"
            android:layout_marginVertical="24dp"
            android:background="@color/green_primary" />

        <!-- descripcion del proyecto -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Aplicación Android para la gestión y venta de entradas deportivas, sincronizada en tiempo real y con generación de códigos QR."
            android:textSize="15sp"
            android:textColor="?attr/colorOnSurface"
            android:textAlignment="center"
            android:lineSpacingExtra="4dp" />

        <!-- separador -->
        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:layout_marginVertical="24dp"
            android:background="?attr/variant01" />

        <!-- seccion de creditos -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Desarrollado por"
            android:textSize="13sp"
            android:textColor="?attr/colorOnSurfaceVariant" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:text="Javi Escobar Fernández"
            android:textSize="16sp"
            android:textStyle="bold"
            android:textColor="?attr/colorOnSurface" />

        <!-- seccion de contexto academico -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:text="Proyecto de fin de grado"
            android:textSize="13sp"
            android:textColor="?attr/colorOnSurfaceVariant" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:text="DAM - Desarrollo de Aplicaciones Multiplataforma"
            android:textSize="14sp"
            android:textColor="?attr/colorOnSurface"
            android:textAlignment="center" />

        <!-- separador -->
        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:layout_marginVertical="24dp"
            android:background="?attr/variant01" />

        <!-- tecnologias utilizadas -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Tecnologías"
            android:textSize="13sp"
            android:textColor="?attr/colorOnSurfaceVariant" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="Kotlin · Firebase · Stripe · Material Design 3"
            android:textSize="14sp"
            android:textColor="?attr/colorOnSurface"
            android:textAlignment="center" />

        <!-- copyright -->
        <TextView
            android:id="@+id/tvCopyright"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="32dp"
            android:textSize="12sp"
            android:textColor="?attr/colorOnSurfaceVariant"
            tools:text="© 2026 PaseDeGol. Todos los derechos reservados." />

    </LinearLayout>

</ScrollView>
