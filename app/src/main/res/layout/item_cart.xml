<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginHorizontal="12dp"
    android:layout_marginVertical="6dp"
    app:cardCornerRadius="6dp"
    app:cardElevation="4dp"
    android:clickable="true"
    android:focusable="true"
    app:cardBackgroundColor="?attr/variant02">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="8dp">

        <!-- fecha -->
        <TextView
            android:id="@+id/tvMatchDate"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textSize="14sp"
            android:layout_marginTop="5dp"
            android:textColor="?attr/colorOnSurfaceVariant"
            tools:text="22 mar"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

        <!-- boton eliminar -->
        <ImageButton
            android:id="@+id/btnDelete"
            android:layout_width="32dp"
            android:layout_height="32dp"
            app:tint="@color/red_dark"
            android:background="@android:color/transparent"
            android:src="@drawable/ic_delete"
            android:scaleType="centerInside"
            android:contentDescription="Eliminar del carrito"
            app:layout_constraintEnd_toEndOf="@id/tvAwayTeam"
            app:layout_constraintTop_toTopOf="parent" />

        <!-- fila para los equipos: escudo local + nombre + hora + escudo visitante + nombre -->

        <!-- nombre equipo local -->
        <TextView
            android:id="@+id/tvHomeTeam"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginEnd="6dp"
            android:paddingTop="6dp"
            android:textSize="14sp"
            android:textColor="?attr/colorOnSurfaceVariant"
            android:maxLines="1"
            android:ellipsize="end"
            tools:text="Barcelona"
            android:textAlignment="textEnd"

            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toStartOf="@id/ivHomeBadge"
            app:layout_constraintTop_toBottomOf="@id/btnDelete" />

        <!-- escudo equipo local -->
        <ImageView
            android:id="@+id/ivHomeBadge"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:layout_marginTop="6dp"
            android:layout_marginEnd="6dp"
            android:contentDescription="Escudo equipo local"
            tools:src="@mipmap/ic_launcher"

            app:layout_constraintStart_toEndOf="@id/tvHomeTeam"
            app:layout_constraintEnd_toStartOf="@id/tvMatchTime"
            app:layout_constraintTop_toTopOf="@id/tvHomeTeam"
            app:layout_constraintBottom_toBottomOf="@id/tvHomeTeam" />


        <!-- hora del partido (centro) -->
        <TextView
            android:id="@+id/tvMatchTime"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textSize="12sp"
            android:textColor="?attr/colorOnSurfaceVariant"
            android:layout_marginHorizontal="8dp"
            tools:text="21:00"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="@id/ivHomeBadge"
            app:layout_constraintBottom_toBottomOf="@id/ivHomeBadge" />

        <!-- escudo equipo visitante -->
        <ImageView
            android:id="@+id/ivAwayBadge"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:layout_marginStart="6dp"
            android:contentDescription="Escudo equipo visitante"
            tools:src="@mipmap/ic_launcher"
            app:layout_constraintStart_toEndOf="@id/tvMatchTime"
            app:layout_constraintEnd_toStartOf="@id/tvAwayTeam"
            app:layout_constraintTop_toTopOf="@id/ivHomeBadge" />

        <!-- nombre equipo visitante -->
        <TextView
            android:id="@+id/tvAwayTeam"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="6dp"
            android:layout_marginEnd="6dp"
            android:paddingTop="6dp"
            android:textSize="14sp"
            android:textColor="?attr/colorOnSurfaceVariant"
            android:maxLines="1"
            android:ellipsize="end"
            tools:text="Betis"
            app:layout_constraintStart_toEndOf="@id/ivAwayBadge"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="@id/tvHomeTeam" />

        <!-- info: cantidad, estadio y precio total -->
        <TextView
            android:id="@+id/tvCartInfo"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_margin="12dp"
            android:textSize="12sp"
            android:textStyle="bold"
            android:textColor="?attr/colorOnSurfaceVariant"
            android:maxLines="1"
            android:ellipsize="end"
            tools:text="2 Entradas - Camp Nou"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toStartOf="@id/tvCartTotal"
            app:layout_constraintTop_toBottomOf="@id/tvHomeTeam" />

        <!-- precio total del item -->
        <TextView
            android:id="@+id/tvCartTotal"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textSize="20sp"
            android:textStyle="bold"
            android:textColor="?attr/colorOnSurface"
            tools:text="240,50 €"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toBottomOf="@id/tvCartInfo"
            app:layout_constraintBottom_toBottomOf="@id/tvCartInfo" />

    </androidx.constraintlayout.widget.ConstraintLayout>

</androidx.cardview.widget.CardView>
